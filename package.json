{
  "name": "iobroker.notificationforandroidtv",
  "version": "3.1.0",
  "description": "Notification integration for IoBroker includes support for Notifications for Android TV and Notifications for Fire TV.",
  "author": "DNAngel <stolly82@web.de>",
  "homepage": "https://github.com/DNAngelX/ioBroker.notificationforandroidtv",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "Notification",
    "TV",
    "Android",
    "Alexa",
    "Benachrichtigungen",
    "Fire TV"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DNAngelX/ioBroker.notificationforandroidtv.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@eslint/js": "^10.0.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node16": "^16.1.8",
    "@types/node": "^25.5.0",
    "@types/proxyquire": "^1.3.31",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "mocha": "^11.0.0",
    "proxyquire": "^2.1.3",
    "typescript": "~5.9.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/DNAngelX/ioBroker.notificationforandroidtv/issues"
  }
}
